{
    "version": "1.0",
    "description": "Configuração dinâmica do sistema Willy",
    "system": {
        "bright": 80,
        "wifiAtStartup": true,
        "startupApp": "WiFi",
        "instantBoot": true,
        "bgColor": 0,
        "themePath": "/themes/default",
        "themeFS": false
    },
    "modules": {
        "wifi": {
            "scanTimeout": 30,
            "maxNetworks": 50
        },
        "rf": {
            "defaultFrequency": 433920000,
            "modulation": "OOK"
        },
        "rfid": {
            "autoRead": true,
            "beepOnRead": true
        }
    },
    "features": {
        "hotReload": true,
        "autoSave": true,
        "debugMode": false
    }
}