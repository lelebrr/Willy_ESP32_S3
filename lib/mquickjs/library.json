{
  "name": "mquickjs",
  "version": "0.0.1",
  "description": "QuickJS JavaScript engine for embedded systems",
  "keywords": [
    "javascript",
    "js",
    "interpreter"
  ],
  "authors": [
    {
      "name": "Fabrice Bellard"
    }
  ],
  "repository": {
    "type": "git",
